+#include <cnat/cnat_types.h>
+#include <cnat/cnat_util.h>
+#include <plugins/cnat/cnat_node.h>
+
+int
+is_feature_enabled_on_sw_if_index (u32 sw_if_index, int is_input)
+{
+  cnat_main_t *cm = &cnat_main;
+  int ret = 0;
+  if (is_input)
+    {
+      ret = clib_bitmap_get (cm->input_feature_on_sw_if_index, sw_if_index);
+    }
+  else
+    {
+      ret = clib_bitmap_get (cm->output_feature_on_sw_if_index, sw_if_index);
+    }
+  return ret;
+}
+
+void
+cnat_feature_hook_input_check (void *p_cnat_main, vlib_buffer_t *b, cnat_timestamp_rewrite_t *rw,
+			       ip_address_family_t af, cnat_timestamp_t *ts)
+{
+  cnat_main_t *cm = (cnat_main_t *) p_cnat_main;
+  u32 in_if = vnet_buffer (b)->sw_if_index[VLIB_RX];
+  if (!is_feature_enabled_on_sw_if_index (in_if, 1))
+    return;
+  /* prefer the rewrite tuple which is post-NAT if a translation exists,
+   * fall back to parsing the buffer directly for non-NAT flows */
+  cnat_5tuple_t tup = { 0 };
+  if (rw != NULL)
+    tup = rw->tuple;
+  else
+    cnat_make_buffer_5tuple (b, af, &tup, 0, 0, NULL);
+  u8 action = 0;
+  u32 npol_matched_rule_id = 0;
+  if (!cm->input_match_func)
+    return;
+  int is_match =
+    (*cm->input_match_func) (cm, in_if, 1, &tup, !(AF_IP4 == af), &action, &npol_matched_rule_id);
+  if (is_match)
+    {
+      clib_warning ("in:: %U => action:%d - interface: %d - npolrule: %d", format_cnat_5tuple, &tup,
+		    action, in_if, npol_matched_rule_id);
+    }
+
+  if (action == 0)
+    {
+      /* clear rewrites and store next drop */
+      ts->cts_dpoi_next_node_input = CNAT_FEATURE_NEXT_DROP;
+      ts->ts_rw_bm = 0;
+    }
+}
+
+void
+cnat_feature_hook_output_check (void *p_cnat_main, vlib_buffer_t *b, ip_address_family_t af,
+				cnat_timestamp_t *ts)
+{
+  cnat_main_t *cm = (cnat_main_t *) p_cnat_main;
+  u32 out_if = vnet_buffer (b)->sw_if_index[VLIB_TX];
+  if (!is_feature_enabled_on_sw_if_index (out_if, 0))
+    return;
+  cnat_5tuple_t tup = { 0 };
+  cnat_make_buffer_5tuple (b, af, &tup, vnet_buffer (b)->ip.save_rewrite_length, 0, NULL);
+
+  u8 action = 0;
+  u32 npol_matched_rule_id = 0;
+  if (!cm->output_match_func)
+    return;
+  int is_match =
+    (*cm->output_match_func) (cm, out_if, 0, &tup, !(AF_IP4 == af), &action, &npol_matched_rule_id);
+  if (is_match)
+    {
+      clib_warning ("out:: %U => action:%d - interface: %d - npolrule: %d", format_cnat_5tuple,
+		    &tup, action, out_if, npol_matched_rule_id);
+    }
+
+  if (action == 0)
+    {
+      /* clear rewrites and store next drop */
+      ts->cts_dpoi_next_node_output = CNAT_FEATURE_NEXT_DROP;
+    }
+}
+
+static int
+feature_hook_add (u32 sw_if_index, int is_input, cnat_feature_hook_match_5tuple_func_t func)
+{
+  cnat_main_t *cm = &cnat_main;
+  cnat_feature_hook_match_5tuple_func_t *p =
+    is_input ? &cm->input_match_func : &cm->output_match_func;
+  uword **pbitmap =
+    is_input ? &cm->input_feature_on_sw_if_index : &cm->output_feature_on_sw_if_index;
+  *p = func;
+  *pbitmap = clib_bitmap_set (*pbitmap, sw_if_index, 1);
+  /* register hook only once, on first interface */
+  if (clib_bitmap_count_set_bits (*pbitmap) == 1)
+    {
+      if (is_input)
+	vec_add1 (cm->slow_path_input_func, cnat_feature_hook_input_check);
+      else
+	vec_add1 (cm->slow_path_output_func, cnat_feature_hook_output_check);
+    }
+  return 0;
+}
+
+static int
+feature_hook_del (u32 sw_if_index, int is_input, cnat_feature_hook_match_5tuple_func_t func)
+{
+  cnat_main_t *cm = &cnat_main;
+  uword **pbitmap =
+    is_input ? &cm->input_feature_on_sw_if_index : &cm->output_feature_on_sw_if_index;
+  *pbitmap = clib_bitmap_set (*pbitmap, sw_if_index, 0);
+  return 0;
+}
+
+__attribute__ ((visibility ("default"))) int
+cnat_feature_hook_add_del (int is_add, u32 sw_if_index, int is_input,
+			   cnat_feature_hook_match_5tuple_func_t func)
+{
+  return is_add ? feature_hook_add (sw_if_index, is_input, func) :
+		  feature_hook_del (sw_if_index, is_input, func);
+}
+
+void
+show_cnat_feature_hooks (vlib_main_t *vm, u32 verbose)
+{
+  cnat_main_t *cm = &cnat_main;
+  vlib_cli_output (vm, "\nCnat Feature hooks:");
+
+  cnat_cli_output_bitmap (vm, cm->input_feature_on_sw_if_index);
+  cnat_cli_output_bitmap (vm, cm->output_feature_on_sw_if_index);
+
+  vlib_cli_output (vm, "\n input function pointer: %p", cm->input_match_func);
+  vlib_cli_output (vm, "\n output function pointer: %p", cm->output_match_func);
+}
+
+static clib_error_t *
+cnat_show_cnat_feature_hooks_fn (vlib_main_t *vm, unformat_input_t *input, vlib_cli_command_t *cmd)
+{
+  clib_error_t *error = 0;
+
+  u32 show_policies_verbose = 0;
+  (void) unformat (input, "verbose %u", &show_policies_verbose);
+
+  show_cnat_feature_hooks (vm, show_policies_verbose);
+  return error;
+}
+
+VLIB_CLI_COMMAND (cnat_show_cnat_feature_hooks, static) = {
+  .path = "show cnat feature-hooks",
+  .short_help = "show cnat feature-hooks [verbose]",
+  .function = cnat_show_cnat_feature_hooks_fn,
+};
